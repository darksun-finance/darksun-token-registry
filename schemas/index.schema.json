{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://darksun.finance/schemas/index.schema.json",
  "title": "DarkSun Registry Index",
  "type": "object",
  "required": ["name", "timestamp", "chains"],
  "properties": {
    "name": { "type": "string" },
    "timestamp": { "type": "string" },
    "chains": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "name", "file"],
        "properties": {
          "key": { "type": "string" },
          "name": { "type": "string" },
          "file": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
