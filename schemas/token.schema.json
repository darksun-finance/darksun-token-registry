{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://darksun.finance/schemas/token.schema.json",
  "title": "DarkSun Token",
  "type": "object",
  "required": [
    "id",
    "chain",
    "type",
    "symbol",
    "name",
    "decimals",
    "verified",
    "tags",
    "logoURI"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "chain": { "type": "string", "enum": ["terra_classic"] },
    "type": { "type": "string", "enum": ["native", "cw20", "ibc"] },
    "symbol": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "denom": { "type": "string" },
    "contract": { "type": "string" },
    "decimals": { "type": "integer", "minimum": 0, "maximum": 30 },
    "logoURI": { "type": "string", "minLength": 1 },
    "coinmarketcapId": { "type": "string" },
    "coingeckoId": { "type": "string" },
    "priceSources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["provider"],
        "properties": {
          "provider": {
            "type": "string",
            "enum": ["coinmarketcap", "coingecko", "vyntrex"]
          },
          "id": { "type": "string" },
          "contract": { "type": "string" },
          "api": { "type": "string" },
          "priority": { "type": "integer", "minimum": 1, "maximum": 10 },
          "enabled": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "website": { "type": "string" },
    "x": { "type": "string" },
    "telegram": { "type": "string" },
    "description": { "type": "string" },
    "verified": { "type": "boolean" },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "cw20" } }, "required": ["type"] },
      "then": { "required": ["contract"] }
    },
    {
      "if": {
        "properties": { "type": { "enum": ["native", "ibc"] } },
        "required": ["type"]
      },
      "then": { "required": ["denom"] }
    }
  ],
  "additionalProperties": false
}
